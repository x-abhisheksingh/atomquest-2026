generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum UoMType {
  MIN
  MAX
  TIMELINE
  ZERO
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  LOCKED
}

enum AchievementStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(EMPLOYEE)
  managerId String?
  manager   User?    @relation("ManagerEmployee", fields: [managerId], references: [id])
  employees User[]   @relation("ManagerEmployee")
  createdAt DateTime @default(now())

  goalSheets  GoalSheet[]
  checkIns    CheckIn[]
  auditLogs   AuditLog[]
  sharedGoals SharedGoal[]
}

model GoalCycle {
  id        String   @id @default(uuid())
  name      String
  year      Int
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  goalSheets GoalSheet[]
}

model GoalSheet {
  id         String     @id @default(uuid())
  employeeId String
  employee   User       @relation(fields: [employeeId], references: [id])
  cycleId    String
  cycle      GoalCycle  @relation(fields: [cycleId], references: [id])
  status     GoalStatus @default(DRAFT)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  goals Goal[]
}

model Goal {
  id          String    @id @default(uuid())
  goalSheetId String
  goalSheet   GoalSheet @relation(fields: [goalSheetId], references: [id])
  thrustArea  String
  title       String
  description String?
  uomType     UoMType
  target      Float
  weightage   Float
  isShared    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  achievements Achievement[]
  checkIns     CheckIn[]
  sharedGoals  SharedGoal[]
  auditLogs    AuditLog[]
}

model SharedGoal {
  id         String @id @default(uuid())
  goalId     String
  goal       Goal   @relation(fields: [goalId], references: [id])
  employeeId String
  employee   User   @relation(fields: [employeeId], references: [id])
  weightage  Float

  @@unique([goalId, employeeId])
}

model Achievement {
  id        String            @id @default(uuid())
  goalId    String
  goal      Goal              @relation(fields: [goalId], references: [id])
  quarter   Quarter
  actual    Float?
  status    AchievementStatus @default(NOT_STARTED)
  updatedAt DateTime          @updatedAt

  @@unique([goalId, quarter])
}

model CheckIn {
  id        String   @id @default(uuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id])
  managerId String
  manager   User     @relation(fields: [managerId], references: [id])
  quarter   Quarter
  comment   String
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  changedBy  String
  changer    User     @relation(fields: [changedBy], references: [id])
  changeType String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  goal   Goal?   @relation(fields: [goalId], references: [id])
  goalId String?
}
